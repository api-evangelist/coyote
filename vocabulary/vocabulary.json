{
  "name": "CoyoteGO API Vocabulary",
  "description": "Terms, operations, and data concepts from the CoyoteGO API for freight logistics",
  "source": "https://api.coyote.com/swagger/v1/swagger.json",
  "operations": [
    {
      "term": "Gets a TL Spot Quote",
      "description": "Allows Shippers to retrieve a Truckload quote. Given a set of shipment attributes as input, Coyote will send back a \r\nquote with a spot quote ID (\u201cspotQuoteId\u201d). This quote includes fuel, unless other"
    },
    {
      "term": "Gets an LTL Spot Quote",
      "description": "Allows Shippers to retrieve a Less-Than-Truckload quote. Given a set of shipment attributes as input, Coyote will \r\nsend back an LTL quote with an LTL spot quote ID (\u201cltlSpotQuoteId\u201d). This quote incl"
    },
    {
      "term": "Submit a load request",
      "description": "Allows Shippers to submit load build requests with relevant load information, including a Spot Quote ID. \\\r\n*Note: Including a Spot Quote ID is currently unsupported in Europe.*"
    },
    {
      "term": "Get load build status",
      "description": "Allows Shippers to retrieve the current load build status for a previously submitted request."
    },
    {
      "term": "Cancel a load",
      "description": "Allows Shippers to cancel a load that was previously submitted."
    },
    {
      "term": "Search loads",
      "description": "Based on a given search term, Coyote will return a list of all loads that match on any of the below reference number types associated to your loads.\r\n```\r\nReferenceNumberType: \r\n    - \"PRONumber\"\r\n   "
    },
    {
      "term": "Gets all load stop details",
      "description": "Allows Shippers to retrieve all load stop details for a given load, including facility information, \r\nas well as appointments, and tracking milestones."
    },
    {
      "term": "Gets load tracking summary",
      "description": "Allows Shippers to retrieve a tracking summary view for a given load, including the latest location update, \r\nnext stop details, and estimated arrival."
    },
    {
      "term": "Gets all tracking updates for a given load",
      "description": "Allows Shippers to retrieve all location updates for a given load."
    },
    {
      "term": "Gets the latest tracking update for a given load",
      "description": "Allows Shippers to retrieve the most recent location updates for a given load."
    },
    {
      "term": "Gets available load details",
      "description": "Allows Carriers to retrieve all the current details for a given load, assuming the provided load is still available."
    },
    {
      "term": "Search available loads",
      "description": "Allows Carriers to search for available loads with a set of query inputs. Coyote will return the list of all available loads that match the inputs provided in the request."
    },
    {
      "term": "Submit a booking request",
      "description": "Allows Carriers to submit a booking request with relevant load information."
    },
    {
      "term": "Get booking request status",
      "description": "Allows Carriers to retrieve the current booking status for a previously submitted booking request."
    },
    {
      "term": "Get existing offer details",
      "description": "Allows Coyote's Carrier to retrieve an existing offer details."
    },
    {
      "term": "Remove offer",
      "description": "Allows Coyote's Carrier to remove pending offer."
    },
    {
      "term": "Create new offer",
      "description": "Allows Coyote's Carrier to create new offer."
    },
    {
      "term": "Book an offer",
      "description": "Allows Coyote's Carrier book an offer."
    },
    {
      "term": "Decline offer",
      "description": "Allows Coyote's Carrier to decline countered offer."
    },
    {
      "term": "Submit a document to be associated with a load",
      "description": "Allows Carriers and Shippers to submit one or more documents that will be saved to a given load they are associated to. Only files up to 20 MB and with specific extensions are allowed. Zips are curren"
    },
    {
      "term": "Get associated entities",
      "description": "Allows Coyote's Carrier and Shipper partners to retrieve all associated entities to their account that can be transacted on behalf of via our API."
    },
    {
      "term": "Gets an associated document with a load",
      "description": "Allows Carriers and Shippers to retrieve one or more PDF documents in a zipped format for a given load they are associated to."
    }
  ],
